# Copy to .env and fill in. NEVER commit .env.
# Secret keys are server-side only — do NOT prefix them with VITE_, that would
# expose them to the browser. Non-secret config (e.g. VITE_TTS_PROVIDER) is
# intentionally VITE_-prefixed so both the browser and Hono read the same value.

XAI_API_KEY=xai-...
ELEVENLABS_API_KEY=...
FISH_AUDIO_API_KEY=...

# Pick which TTS provider /api/tts dispatches to. The browser (Vite) and
# the Hono server read the same VITE_-prefixed name so they never disagree.
# Default = fish-audio (S2-Pro). Set to `elevenlabs` to A/B compare.
# VITE_TTS_PROVIDER=fish-audio

# Optional: override the xAI base URL. Defaults to the eu-west-1 regional
# endpoint (https://eu-west-1.api.x.ai/v1) which measures ~500ms first-token
# vs the global api.x.ai/v1 endpoint which floors around 4s.
# Regions reference: https://docs.x.ai/developers/regions
# XAI_BASE_URL=https://eu-west-1.api.x.ai/v1

# Optional: override the default TTS voice. Defaults to Rachel (21m00Tcm4TlvDq8ikWAM).
# List voices: https://api.elevenlabs.io/v1/voices
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Optional: override the Fish Audio API base URL (e.g. for a self-hosted
# inference server). Defaults to https://api.fish.audio.
# FISH_AUDIO_BASE_URL=https://api.fish.audio

# Optional: override the default server port
# PORT=8787
