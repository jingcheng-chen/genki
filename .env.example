# Copy to .env and fill in. NEVER commit .env.
# These are server-side only. Do NOT prefix with VITE_ — that would expose them to the browser.

XAI_API_KEY=xai-...
ELEVENLABS_API_KEY=...

# Optional: override the xAI base URL. Defaults to the eu-west-1 regional
# endpoint (https://eu-west-1.api.x.ai/v1) which measures ~500ms first-token
# vs the global api.x.ai/v1 endpoint which floors around 4s.
# Regions reference: https://docs.x.ai/developers/regions
# XAI_BASE_URL=https://eu-west-1.api.x.ai/v1

# Optional: override the default TTS voice. Defaults to Rachel (21m00Tcm4TlvDq8ikWAM).
# List voices: https://api.elevenlabs.io/v1/voices
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Optional: override the default server port
# PORT=8787
