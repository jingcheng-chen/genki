    "dotenv": "^17.4.2",
    "fake-indexeddb": "^6.2.5",
    "hono": "^4.12.14",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
