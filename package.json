    "@ricky0123/vad-web": "^0.0.30",
    "i18next": "^26.0.7",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb-keyval": "^6.2.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "three": "^0.184.0",
    "wlipsync": "^1.3.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@elevenlabs/elevenlabs-js": "^2.44.0",
