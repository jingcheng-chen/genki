    "@pixiv/three-vrm-animation": "^3.5.2",
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "i18next": "^23.16.4",
    "i18next-browser-languagedetector": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.1",
    "three": "^0.169.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@elevenlabs/elevenlabs-js": "^2.0.0",
    "@hono/node-server": "^1.13.2",
    "@openrouter/ai-sdk-provider": "^0.0.6",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react-swc": "^3.7.1",
    "ai": "^4.0.0",
    "concurrently": "^9.0.1",
    "dotenv": "^16.4.5",
    "hono": "^4.6.10",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
